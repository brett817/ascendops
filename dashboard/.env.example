# cortextOS Dashboard Configuration
# Copy to .env and fill in your values

# ============================================================
# REQUIRED — set by /onboarding, do not edit manually
# ============================================================

# Path to cortextOS state directory
# Created by `cortextos init` (default: ~/.cortextos/default)
CTX_ROOT=~/.cortextos/default

# Path to the cortextOS repo root
CTX_FRAMEWORK_ROOT=/path/to/cortextos

# Dashboard auth secret — generate with: openssl rand -base64 32
# If unset, the dashboard will refuse to start (no insecure fallback)
AUTH_SECRET=your-secret-here

# Dashboard admin credentials are created during onboarding / first login
# ADMIN_USERNAME=<set by /onboarding>
# ADMIN_PASSWORD=<set by /onboarding>

# ============================================================
# OPTIONAL — only set these if you expose the dashboard externally
# (e.g. Cloudflare Tunnel, ngrok, reverse proxy)
# Skip this whole section for local-only use.
# ============================================================

# Public URL where the dashboard is reachable (e.g. Cloudflare Tunnel URL)
# NEXTAUTH_URL=https://your-tunnel.trycloudflare.com

# Required if NEXTAUTH_URL is set above
# AUTH_TRUST_HOST=true

# Additional allowed origin for CORS (if different from NEXTAUTH_URL)
# DASHBOARD_URL=https://your-dashboard-url.example.com

# Mobile app CORS origin (only if you use the iOS/Android cortextOS app)
# MOBILE_APP_ORIGIN=https://your-tunnel.trycloudflare.com

# Instance ID — only change if running multiple cortextOS instances on one machine
# CTX_INSTANCE_ID=default
