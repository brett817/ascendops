node_modules/
.claude/
!.claude/commands/
!.claude/commands/**
!.claude/orchestration-cortextos-node/
!.claude/skills/
!.claude/skills/**
# Include template .claude dirs (needed for agent settings.json)
!templates/**/.claude/
!templates/**/.claude/**
dist/
ecosystem.config.js

# User-created org data (not part of the framework)
orgs/
# But community subdirectories ARE part of the framework
!community/
!community/**

# Secrets
.env
.env.*
!.env.example
!**/.env.example
secrets.env
templates/*/.env
.cortextos-env

# Agent runtime data
orgs/*/agents/*/memory/
agents/*/local/
agents/*/telegram-images/
agents/*/memory/

# macOS metadata
.DS_Store

# Test artifacts
test-results/
*.log
# Spurious directory created when ${APPDATA} env var unexpanded during npm link on Windows
${APPDATA}/

# Knowledge base
knowledge-base/venv/
knowledge-base/__pycache__/
knowledge-base/scripts/__pycache__/
knowledge-base/scripts/_test_clients/__pycache__/
tests/playwright/dashboard-ui.spec.ts

# Local ops docs (personal, not for public repo)
docs/

# Carve-out (org-state-persistence-policy 2026-05-22): tracked durable org docs.
# Chain re-includes parent dirs because gitignore cannot re-include files under
# an ignored parent dir. Applied AFTER both orgs/ (line 15) and docs/ (line 52)
# so last-match-wins precedence takes effect on durable/ specifically.
# Strict containment: only orgs/<org>/docs/durable/** + orgs/<org>/knowledge.md
# are the intended carve-outs; ALL other orgs/ contents (agents/, secrets,
# brand-voice, scripts, community, etc.) stay ignored via aggressive re-exclude.
# knowledge.md added 2026-05-23 per Option A of C4 dispatch — it IS doctrine per
# Memory Architecture Policy (4/18), same class as durable/ contents.
!orgs/
orgs/*
!orgs/*/
orgs/*/*
!orgs/*/docs/
orgs/*/docs/*
!orgs/*/docs/durable/
!orgs/*/docs/durable/**
!orgs/*/knowledge.md
# research-artifacts/ — convention dir for contract-at-dispatch v2
# RESEARCH_ARTIFACT_PATH sub-bullet. The directory shell + its own
# .gitignore land here so the convention path resolves for receivers,
# but the contents stay blocked by default (transient session artifacts).
# Promotion to durable = move to docs/durable/ per separate decision.
# Multi-org defense-in-depth: re-block contents at top-level too, so a
# fork org that creates orgs/<neworg>/research-artifacts/ without the
# in-dir .gitignore guard still has contents blocked by default.
!orgs/*/research-artifacts/
orgs/*/research-artifacts/*
!orgs/*/research-artifacts/.gitignore

# Internal developer/planning notes (not for public repo)
KNOWN-ISSUES.md
WINDOWS-IMPLEMENTATION-PLAN.md
WINDOWS-SUPPORT-INVESTIGATION.md
BRAINDUMP*.md
AGENTS.md
# But AGENTS.md inside templates/ is a static template file that must ship.
!templates/**/AGENTS.md
dashboard/screenshots/
dashboard/test-*.py
graphify-out/

# Weekly tool-update generated logs
logs/weekly-tool-update/*.md
!logs/weekly-tool-update/.gitkeep

# Local vendor research checkout — not runtime load-bearing
vendor/everything-claude-code/
