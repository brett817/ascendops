!.claude/commands/**
!.claude/orchestration-cortextos-node/
!.claude/skills/
!.claude/skills/**
# Include template .claude dirs (needed for agent settings.json)
!templates/**/.claude/
!templates/**/.claude/**
dist/
ecosystem.config.js

# User-created org data (not part of the framework)
orgs/
# But community subdirectories ARE part of the framework
!community/
!community/**

# Secrets
.env
.env.*
!.env.example
!**/.env.example
secrets.env
templates/*/.env
.cortextos-env

# Agent runtime data
orgs/*/agents/*/memory/
agents/*/local/
agents/*/telegram-images/
agents/*/memory/

# macOS metadata
.DS_Store

# Test artifacts
test-results/
*.log
# Spurious directory created when ${APPDATA} env var unexpanded during npm link on Windows
${APPDATA}/

# Knowledge base
knowledge-base/venv/
knowledge-base/__pycache__/
knowledge-base/scripts/__pycache__/
knowledge-base/scripts/_test_clients/__pycache__/
tests/playwright/dashboard-ui.spec.ts

# Local ops docs (personal, not for public repo)
docs/

# Carve-out (org-state-persistence-policy 2026-05-22): tracked durable org docs.
# Chain re-includes parent dirs because gitignore cannot re-include files under
# an ignored parent dir. Applied AFTER both orgs/ (line 15) and docs/ (line 52)
# so last-match-wins precedence takes effect on durable/ specifically.
# Strict containment: only orgs/<org>/docs/durable/** is the intended carve-out;
# ALL other orgs/ contents (agents/, secrets, knowledge, brand-voice, scripts,
# community, nested .gitignore, etc.) stay ignored via aggressive re-exclude.
# Known side effect: nested orgs/.gitignore line 8 (!**/*.env.example) was always
# trying to track .env.example template files but the parent orgs/ lock hid them.
# Post-carve-out, those template files become visible as the nested rule intended.
# They are placeholder-only by design — no real secrets — but flagged here for
# audit-trail clarity per the org-state-persistence-policy doc §4.2 amendments.
!orgs/
orgs/*
!orgs/*/
orgs/*/*
!orgs/*/docs/
orgs/*/docs/*
!orgs/*/docs/durable/
!orgs/*/docs/durable/**

# Internal developer/planning notes (not for public repo)
KNOWN-ISSUES.md
WINDOWS-IMPLEMENTATION-PLAN.md
WINDOWS-SUPPORT-INVESTIGATION.md
BRAINDUMP*.md
AGENTS.md
# But AGENTS.md inside templates/ is a static template file that must ship.
!templates/**/AGENTS.md
dashboard/screenshots/
dashboard/test-*.py
graphify-out/

# Weekly tool-update generated logs
logs/weekly-tool-update/*.md
!logs/weekly-tool-update/.gitkeep

# Local vendor research checkout — not runtime load-bearing
vendor/everything-claude-code/
