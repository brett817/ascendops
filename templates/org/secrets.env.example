# Org-level shared secrets
# Copy this file to orgs/<org>/secrets.env and fill in only what you use.
# NEVER commit a populated secrets.env file.

# Required for the Knowledge Base and semantic search
GEMINI_API_KEY=

# Optional shared provider keys
# OPENAI_API_KEY=
# APIFY_TOKEN=

# Optional activity-channel bot for fleet-wide activity posts
# Use templates/org/activity-channel.env.example for the dedicated activity chat file.
# ACTIVITY_BOT_TOKEN=
# ACTIVITY_CHAT_ID=

# Legacy / orphan-risk: older org scaffolds still create these keys in secrets.env.
# Prefer per-agent .env files for Telegram bots and the dedicated activity-channel file above.
# BOT_TOKEN=
# CHAT_ID=
# ACTIVITY_CHAT_ID=
